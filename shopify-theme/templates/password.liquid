<div class="password-page">
  {%- if settings.logo -%}
    <img src="{{ settings.logo | image_url: width: 240 }}" alt="{{ shop.name }}">
  {%- else -%}
    <img src="{{ 'logo.jpeg' | asset_url }}" alt="{{ shop.name }}">
  {%- endif -%}
  <div class="eyebrow" style="color: var(--warehouse-yellow);">{{ shop.name | upcase }}</div>
  <h1>{{ 'general.password.login_form_heading' | t }}</h1>
  <p>We're getting the warehouse stocked. Got the password? Step in.</p>

  {% form 'storefront_password' %}
    <input type="password" name="password" id="password" placeholder="{{ 'general.password.login_form_password_placeholder' | t }}" required>
    <button type="submit" class="btn btn-primary">{{ 'general.password.login_form_submit' | t }}</button>
    {%- if form.errors -%}
      <div class="err">{{ 'general.password.login_form_error' | t }}</div>
    {%- endif -%}
  {% endform %}

  <div style="margin-top: 32px; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.08em; color: #888;">
    {{ settings.city | upcase }} · OPENING SOON
  </div>
</div>
